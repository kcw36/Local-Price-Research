# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required for LLM extraction fallback and summary layer
ANTHROPIC_API_KEY=your-api-key-here

# Scraper settings
AREA=Solihull
TRADE_TYPE=plumbers
MAX_BUSINESSES=20
POLITENESS_DELAY_SECONDS=1.5
JOB_TIMEOUT_SECONDS=600

# Feature flags
# Set to true to enable LLM extraction on pages where regex finds nothing
# Costs ~£0.01/run at MVP scale; keep false until regex coverage validated
LLM_FALLBACK_ENABLED=false

# Database
DATABASE_PATH=jobs.db
